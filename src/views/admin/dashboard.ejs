<%- include("../partials/head.ejs", { titulo }) %>
    <%- include("../partials/header.ejs", { rutaActual }) %>

        <main>
            <h2 class="pg-titulo"><%= detalle %></h2>

            <div class="listado-opciones">
                <% generos.forEach(genero=> { %>
                    <a href="#<%= genero.toLowerCase().replace(' ', '-') %>" class="categoria-link">
                        <%= genero %>
                    </a>
                    <% }); %>
            </div>

            <div class="informacion-general">
                <div class="estadistica">
                    <h3>Total libros</h3>
                    <p>
                        <%= estadisticas.totalLibros %>
                    </p>
                </div>
                <div class="estadistica">
                    <h3>Activos</h3>
                    <p>
                        <%= estadisticas.activos %>
                    </p>
                </div>
                <div class="estadistica">
                    <h3>Inactivos</h3>
                    <p>
                        <%= estadisticas.inactivos %>
                    </p>
                </div>
            </div>

            <!-- Contenedor de libros -->
            <% generos.forEach(genero=> { %>
                <section id="<%= genero.toLowerCase().replace(/ /g, '-') %>">
                    <h2 class="h2-separador">
                        <%= genero %>
                    </h2>
                    <div class="contenedor-libros">
                        <% const libros=librosPorGenero[genero] || []; %>
                            <% if (libros.length===0) { %>
                                <p>No hay libros en esta categoría.</p>
                                <% } else { %>
                                    <% libros.forEach(libro=> { %>
                                        <%- include("../partials/tarjeta-libro.ejs", { libro }) %>
                                            <% }); %>
                                                <% } %>
                    </div>
                </section>
                <% }); %>
        </main>

        <%- include("../partials/footer.ejs") %>